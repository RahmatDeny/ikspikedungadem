# ============================================================
# Firebase Web App Config (dari Firebase Console > Project Settings)
# ============================================================
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# ============================================================
# Cloudflare Worker endpoint (untuk upload gambar ke R2)
# Contoh: https://ikspi-r2-uploader.your-subdomain.workers.dev
# ============================================================
VITE_R2_WORKER_URL=https://your-worker.workers.dev

# Public base URL bucket R2 (custom domain / r2.dev public access)
VITE_R2_PUBLIC_BASE_URL=https://media.example.com
